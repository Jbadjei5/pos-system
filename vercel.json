{
  "version": 2,
  "builds": [
    {
      "src": "main.html",
      "use": "@vercel/static"
    },
    {
      "src": "login.html",
      "use": "@vercel/static"
    },
    {
      "src": "signup.html",
      "use": "@vercel/static"
    },
    {
      "src": "pos.js",
      "use": "@vercel/static"
    },
    {
      "src": "api-config.js",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/",
      "dest": "/main.html"
    },
    {
      "src": "/login",
      "dest": "/login.html"
    },
    {
      "src": "/signup",
      "dest": "/signup.html"
    },
    {
      "src": "/api/(.*)",
      "dest": "https://your-render-backend-url.onrender.com/api/$1"
    }
  ],
  "env": {
    "RENDER_API_URL": "https://your-render-backend-url.onrender.com"
  }
}
